{
  "application": "sample-node-mysql",
  "environment": "dev",
  "description": "Synthetic scenarios for validating LGTM telemetry ingestion through Alloy.",
  "scenarios": [
    {
      "id": "http-list-tutorials",
      "type": "http",
      "method": "GET",
      "path": "/api/tutorials",
      "expectedStatus": 200,
      "expectedTelemetry": {
        "logs": true,
        "metrics": ["http_server_requests_total", "http_server_duration_seconds"],
        "trace": true,
        "dbSpan": true
      }
    },
    {
      "id": "http-create-tutorial",
      "type": "http",
      "method": "POST",
      "path": "/api/tutorials",
      "body": {
        "title": "Synthetic LGTM tutorial",
        "description": "Generated during Deploy_LGTM integration tests",
        "published": true
      },
      "expectedStatus": 201,
      "expectedTelemetry": {
        "logs": true,
        "metrics": ["http_server_requests_total"],
        "trace": true,
        "dbSpan": true
      }
    },
    {
      "id": "http-error",
      "type": "http",
      "method": "GET",
      "path": "/api/tutorials?force_error=true",
      "expectedStatus": 500,
      "expectedTelemetry": {
        "logs": true,
        "metrics": ["http_server_requests_total"],
        "trace": true,
        "errorSpan": true
      }
    },
    {
      "id": "frontend-error",
      "type": "browser-event",
      "path": "/checkout",
      "event": {
        "event_type": "javascript_error",
        "severity": "error",
        "message": "Synthetic frontend exception",
        "duration_ms": 0
      },
      "expectedTelemetry": {
        "logs": true,
        "metrics": ["frontend_errors_total"],
        "trace": false
      }
    },
    {
      "id": "mysql-health",
      "type": "mysql-exporter",
      "expectedMetrics": [
        "mysql_up",
        "mysql_global_status_threads_connected",
        "mysql_global_status_questions"
      ]
    }
  ],
  "expectedLabels": {
    "app": "sample-node-mysql",
    "environment": "dev",
    "namespace": "sample-app",
    "service": "api",
    "component": "backend"
  }
}
